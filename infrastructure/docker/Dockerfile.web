# ============================================================================
# Alchymine Web — Multi-stage Dockerfile (Next.js)
# Stages: deps -> builder -> runner
# ============================================================================

# ─── Stage 1: Dependencies ────────────────────────────────────────────────
FROM node:20-alpine AS deps

RUN apk add --no-cache libc6-compat

WORKDIR /app

# Copy package files for dependency installation (layer caching)
COPY alchymine/web/package.json alchymine/web/package-lock.json* ./

# Install dependencies
RUN if [ -f package-lock.json ]; then \
        npm ci --ignore-scripts; \
    else \
        npm install --ignore-scripts; \
    fi

# ─── Stage 2: Builder ─────────────────────────────────────────────────────
FROM node:20-alpine AS builder

WORKDIR /app

# Copy dependencies from deps stage
COPY --from=deps /app/node_modules ./node_modules

# Copy application source
COPY alchymine/web/ ./

# Accept build args
ARG APP_VERSION=dev
# Empty string → relative URLs in the browser (nginx proxies /api/ to FastAPI).
# Override for dev: NEXT_PUBLIC_API_URL=http://localhost:8000
ARG NEXT_PUBLIC_API_URL=

# Set build-time environment variables
# NEXT_PUBLIC_* vars are baked into the client JS bundle at build time.
ENV NEXT_TELEMETRY_DISABLED=1 \
    NODE_ENV=production \
    APP_VERSION=${APP_VERSION} \
    NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}

# Build the Next.js application
RUN npm run build

# ─── Stage 3: Runner ──────────────────────────────────────────────────────
FROM node:20-alpine AS runner

LABEL maintainer="Alchymine <tyler@futuretalk.ca>"
LABEL description="Alchymine Web - Next.js frontend application"

WORKDIR /app

# Set runtime environment variables
ENV NODE_ENV=production \
    NEXT_TELEMETRY_DISABLED=1 \
    HOSTNAME="0.0.0.0" \
    PORT=3000

# Install tini for proper signal handling
RUN apk add --no-cache tini

# Upgrade npm + transitive deps to fix system-level vulnerabilities
# (cross-spawn CVE-2024-21538, glob CVE-2025-64756, tar GHSA-qffp-2rhf-9h96)
# Remaining minimatch CVEs in npm internals are handled via .trivyignore
RUN npm install -g npm@latest && \
    # Force-update tar to pick up path traversal fix (>=7.5.10)
    cd /usr/local/lib/node_modules/npm && npm update tar --save && \
    npm cache clean --force

# Create non-root user
RUN addgroup --system --gid 1001 alchymine && \
    adduser --system --uid 1001 alchymine

# Copy built application from builder stage
# Next.js standalone output includes only what is needed
COPY --from=builder /app/public ./public

# Copy standalone output if it exists (next.config.js must have output: 'standalone')
COPY --from=builder --chown=alchymine:alchymine /app/.next/standalone ./
COPY --from=builder --chown=alchymine:alchymine /app/.next/static ./.next/static

# Switch to non-root user
USER alchymine

EXPOSE 3000

# Health check
HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
    CMD node -e "require('http').get('http://localhost:3000/api/health', (r) => { process.exit(r.statusCode === 200 ? 0 : 1) }).on('error', () => process.exit(1))"

# Use tini as init system
ENTRYPOINT ["tini", "--"]

# Start the Next.js standalone server
CMD ["node", "server.js"]
