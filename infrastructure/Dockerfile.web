# ============================================================================
# Alchymine Web — Multi-stage Dockerfile (Next.js)
# Stages: deps -> builder -> runner
# ============================================================================

# ─── Stage 1: Dependencies ────────────────────────────────────────────────
FROM node:20-alpine AS deps

RUN apk add --no-cache libc6-compat

WORKDIR /app

# Copy package files for dependency installation (layer caching)
COPY alchymine/web/package.json alchymine/web/package-lock.json* ./

# Install dependencies
RUN if [ -f package-lock.json ]; then \
        npm ci --ignore-scripts; \
    else \
        npm install --ignore-scripts; \
    fi

# ─── Stage 2: Builder ─────────────────────────────────────────────────────
FROM node:20-alpine AS builder

WORKDIR /app

# Copy dependencies from deps stage
COPY --from=deps /app/node_modules ./node_modules

# Copy application source
COPY alchymine/web/ ./

# Set build-time environment variables
ENV NEXT_TELEMETRY_DISABLED=1 \
    NODE_ENV=production

# Build the Next.js application (output: standalone via next.config.mjs)
RUN npm run build

# ─── Stage 3: Runner ──────────────────────────────────────────────────────
FROM node:20-alpine AS runner

LABEL maintainer="Alchymine <tyler@futuretalk.ca>"
LABEL description="Alchymine Web - Next.js frontend application"

WORKDIR /app

# Set runtime environment variables
ENV NODE_ENV=production \
    NEXT_TELEMETRY_DISABLED=1 \
    HOSTNAME="0.0.0.0" \
    PORT=3000

# Install curl for health checks and tini for init
RUN apk add --no-cache curl tini

# Create non-root user
RUN addgroup --system --gid 1001 alchymine && \
    adduser --system --uid 1001 alchymine

# Copy built application from builder stage
COPY --from=builder /app/public ./public

# Copy standalone output (next.config.mjs has output: 'standalone')
COPY --from=builder --chown=alchymine:alchymine /app/.next/standalone ./
COPY --from=builder --chown=alchymine:alchymine /app/.next/static ./.next/static

# Switch to non-root user
USER alchymine

EXPOSE 3000

# Health check
HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
    CMD curl -f http://localhost:3000/ || exit 1

# Use tini as init system
ENTRYPOINT ["tini", "--"]

# Start the Next.js standalone server
CMD ["node", "server.js"]
