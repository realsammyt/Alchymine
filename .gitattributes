# Auto-detect text files and normalize line endings to LF in the repo.
# Developers on Windows will see CRLF in their working tree (via core.autocrlf),
# but the repo always stores LF — preventing noisy diffs from line-ending mismatches.

* text=auto eol=lf

# ─── Explicitly text (always normalize) ───────────────────────────────────
*.py        text eol=lf
*.pyi       text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.json      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.md        text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.xml       text eol=lf
*.svg       text eol=lf
*.sql       text eol=lf
*.sh        text eol=lf
*.toml      text eol=lf
*.cfg       text eol=lf
*.ini       text eol=lf
*.env       text eol=lf
*.txt       text eol=lf
Dockerfile* text eol=lf
Makefile    text eol=lf
.gitignore  text eol=lf
.gitattributes text eol=lf

# ─── Explicitly binary (never normalize) ──────────────────────────────────
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.webp      binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
*.pdf       binary
*.zip       binary
*.tar.gz    binary
*.lock      linguist-generated
