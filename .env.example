# Alchymine Environment Configuration
# Copy to .env and fill in values.
#
# All variables below are consumed by alchymine.config.Settings (Pydantic
# BaseSettings).  Variable names are case-insensitive.

# ─── App ─────────────────────────────────────────────────────────────────
APP_NAME=Alchymine
DEBUG=false
ENVIRONMENT=development  # development | staging | production

# ─── CORS ────────────────────────────────────────────────────────────────
# JSON list of allowed origins, e.g. '["https://app.example.com"]'
ALLOWED_ORIGINS=["http://localhost:3000"]

# ─── Auth / JWT ──────────────────────────────────────────────────────────
# IMPORTANT: In production, JWT_SECRET_KEY MUST be changed from the default.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=dev-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Database ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://alchymine:alchymine@localhost:5432/alchymine

# Docker Compose also uses these for the PostgreSQL container:
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=alchymine
POSTGRES_USER=alchymine
POSTGRES_PASSWORD=changeme_in_production

# ─── Redis ───────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_URL=redis://localhost:6379/1

# ─── Celery ──────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_ALWAYS_EAGER=false
CELERY_WORKER_CONCURRENCY=4

# ─── LLM ─────────────────────────────────────────────────────────────────
# Recommended: Anthropic Claude API
ANTHROPIC_API_KEY=
LLM_PROVIDER=anthropic  # anthropic | ollama
LLM_MODEL=claude-sonnet-4-20250514

# Fallback: Ollama local
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ─── API (non-Settings — used by Docker / uvicorn) ───────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RATE_LIMIT_FREE=100
API_RATE_LIMIT_PAID=1000

# ─── Frontend ────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=Alchymine
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Email ───────────────────────────────────────────────────────────────
EMAIL_PROVIDER=resend  # resend | sendgrid
RESEND_API_KEY=
SENDGRID_API_KEY=
EMAIL_FROM=noreply@alchymine.app

# ─── Stripe (Creator Dashboard) ──────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Security ────────────────────────────────────────────────────────────
ENCRYPTION_KEY=changeme_generate_with_openssl_rand_hex_32
# Financial data encryption key (separate from main encryption)
FINANCIAL_ENCRYPTION_KEY=changeme_generate_with_openssl_rand_hex_32

# ─── Swiss Ephemeris ─────────────────────────────────────────────────────
SWISSEPH_DATA_PATH=/usr/share/swisseph

# ─── Logging ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
