# ============================================================================
# Alchymine — Production Environment Variables
# Copy this file to .env.production and fill in all values.
#
#   cp .env.production.example .env.production
#
# IMPORTANT: Never commit .env.production to version control.
# ============================================================================

# ── Domain & SSL ─────────────────────────────────────────────────────────────
DOMAIN=alchymine.com
SSL_EMAIL=admin@alchymine.com

# ── Application ──────────────────────────────────────────────────────────────
ENVIRONMENT=production
LOG_LEVEL=WARNING
ALLOWED_ORIGINS=https://alchymine.com

# ── API Security ─────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
API_SECRET_KEY=changeme_generate_with_openssl_rand_hex_32
JWT_SECRET_KEY=changeme_generate_with_openssl_rand_hex_32
API_CORS_ORIGINS=["https://alchymine.com","https://www.alchymine.com"]

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=alchymine
POSTGRES_USER=alchymine
POSTGRES_PASSWORD=changeme_use_strong_password
DATABASE_URL=postgresql+asyncpg://alchymine:changeme_use_strong_password@db:5432/alchymine

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_URL=redis://redis:6379/1
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ── Celery ───────────────────────────────────────────────────────────────────
CELERY_WORKER_CONCURRENCY=4

# ── Next.js Frontend ─────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://alchymine.com/api
WEB_PORT=3000
API_PORT=8000

# ── Claude API (for LLM features) ───────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-changeme
# Ollama fallback (optional, for local-first LLM)
# OLLAMA_BASE_URL=http://ollama:11434

# ── Backup ───────────────────────────────────────────────────────────────────
BACKUP_RETENTION=30
